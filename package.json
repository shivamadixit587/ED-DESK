{
  "name": "ed-desk",
  "version": "1.0.0",
  "description": "ED-DESK - Offline Desktop Application for Academic Communication and Assessment",
  "main": "dist/main/index.js",
  "author": "ED-DESK Team",
  "license": "MIT",
  "homepage": "https://github.com/ed-desk/app",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "clean": "rm -rf dist out node_modules/.vite",
    "clean:win": "rimraf dist out node_modules/.vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "ethers": "^6.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "webrtc-adapter": "^9.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "ganache": "^7.9.2",
    "rimraf": "^5.0.10",
    "typescript": "^5.8.3",
    "vite": "^5.4.18"
  },
  "build": {
    "appId": "com.eddesk.app",
    "productName": "ED-DESK",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png",
      "category": "Education"
    }
  }
}
